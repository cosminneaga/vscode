	"editor.semanticTokenColorCustomizations": {
		"enabled": true,
		"rules": {
			"class": { "foreground": "#8DE969", "fontStyle": "italic" },
			"class.declaration": {},
			"class.deprecated": { "foreground": "#6B6B6B", "fontStyle": "italic" },
			"class.static": "#E5C07B",
			"comment": { "foreground": "#6A9955", "fontStyle": "italic" },
			"decorator": "#FFD700",
			"enum": "#B5CEA8",
			"enumMember": "#D19A66",
			"event": { "foreground": "#FF9E64", "fontStyle": "bold underline" },
