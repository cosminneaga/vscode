			"function.async": { "fontStyle": "" },
			"function.declaration": { "fontStyle": "" },
			"interface": "#9CDCFE",
			"keyword": { "foreground": "#3D5A6C" },
			"label": "#EF476F",
			"macro": "#FF00FF",
