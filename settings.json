			"variable.defaultLibrary": "#8899FF",
			"variable.readonly": { "foreground": "#94ccf4", "fontStyle": "italic" },
			"variable.static": "#E5C07B",
			"variable.global": { "fontStyle": "bold" },
			"*.unused": { "foreground": "#6B6B6B" },
		},
	},
