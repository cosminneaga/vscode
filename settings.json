			"method.async": { "fontStyle": "" },
			"method.declaration": { "fontStyle": "" },
			"modifier": "#FF6B6B",
			"namespace": "#7AA2F7",
			"number": "#D19A66",
			"operator": "#56B6C2",
			"parameter": { "foreground": "#9CDCFE", "fontStyle": "italic" },
			"parameter.declaration": {},
			"property": { "foreground": "#C2D076" },
			"property.readonly": { "fontStyle": "bold" },
			"regexp": "#D16969",
			"string": "#98C379",
			"struct": "#FFD580",
			"type": "#FFD580",
			"typeParameter": "#FFC66D",
			"variable": "#FFB86C",
